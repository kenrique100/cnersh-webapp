# Database - Supabase PostgreSQL connection strings
# Pooled connection (used by the application at runtime via PgBouncer transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct / session-mode connection (REQUIRED for Prisma migrations and db push)
# PgBouncer transaction mode (port 6543) does NOT support prepared statements,
# so migrations must use port 5432 (session mode) or a direct database connection.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres"
#
# NOTE: If your database password contains special characters like / ? @ # %
# they are automatically URL-encoded by the application. You can paste the
# password as-is from your Supabase dashboard.

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-here"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (for sending emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="CNEC <noreply@yourdomain.com>"

# Admin Seed (optional - used by `npm run db:seed`)
# If not set, defaults to admin@cnec.cm / Admin@CNEC2026
ADMIN_EMAIL="admin@cnec.cm"
ADMIN_PASSWORD="Admin@CNEC2026"
ADMIN_NAME="CNEC Admin"

# UploadThing (for file uploads)
UPLOADTHING_TOKEN="your-uploadthing-token-here"
