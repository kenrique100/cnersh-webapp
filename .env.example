# Database - PostgreSQL connection strings (Neon, Supabase, or any PostgreSQL provider)
#
# Pooled connection (used by the application at runtime)
# Neon example (note the -pooler suffix in the hostname):
DATABASE_URL="postgresql://neondb_owner:[password]@ep-[slug]-pooler.[region].aws.neon.tech/neondb?sslmode=require"
#
# Direct connection (REQUIRED for Prisma migrations and db push — non-pooled)
# Neon example (no -pooler suffix):
DIRECT_URL="postgresql://neondb_owner:[password]@ep-[slug].[region].aws.neon.tech/neondb?sslmode=require"
#
# IMPORTANT: Both DATABASE_URL and DIRECT_URL must point to the SAME database.
# DATABASE_URL uses the pooled endpoint for better runtime performance.
# DIRECT_URL uses the direct endpoint for migrations (poolers don't support DDL well).
#
# NOTE: If your database password contains special characters like / ? @ # %
# they are automatically URL-encoded by the application. You can paste the
# connection string as-is from your provider's dashboard.

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-here"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (for sending emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="CNEC <noreply@yourdomain.com>"

# Admin Seed (optional - used by `npm run db:seed`)
# If not set, defaults to admin@cnec.cm / Admin@CNEC2026
ADMIN_EMAIL="admin@cnec.cm"
ADMIN_PASSWORD="Admin@CNEC2026"
ADMIN_NAME="CNEC Admin"

# UploadThing (for file uploads)
UPLOADTHING_TOKEN="your-uploadthing-token-here"
