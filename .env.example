# Database - PostgreSQL connection strings
# Pooled connection (used by the application at runtime)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct connection (used for migrations - often a non-pooled URL)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-here"
# Comma-separated list of trusted origins for CSRF protection (e.g., your deployed domain)
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:3000"

# Public-facing app URL (used by auth client for API requests)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (for sending emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="CNERSH <info@cameroon-national-ethics-com.net>"

# Vercel Blob (for file storage - images, videos, documents)
# Provision in Vercel dashboard: Storage → Blob → Create Store
# The token is auto-populated in Vercel deployments; set it manually for local development
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token_here"

# UploadThing (required for UploadThing-backed image uploads)
UPLOADTHING_TOKEN="sk_live_your_uploadthing_token_here"

# Admin Seed (optional - used by `npm run db:seed`)
# If not set, defaults to the values shown below
SUPER_ADMIN_EMAIL="superadmin@cnersh.cm"
SUPER_ADMIN_PASSWORD="SuperAdmin@cnersh2026!"
SUPER_ADMIN_NAME="CNERSH Super Admin"
ADMIN_EMAIL="admin@cnersh.cm"
ADMIN_PASSWORD="Admin@cnersh2026!"
ADMIN_NAME="CNERSH Admin"

UPLOADTHING_TOKEN='uploadthing_token'
