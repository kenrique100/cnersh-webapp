# Database - PostgreSQL connection strings
# Pooled connection (used by the application at runtime)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Direct connection (used for migrations - often a non-pooled URL)
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Better Auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="your-secret-key-here"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend (for sending emails)
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="CNEC <noreply@yourdomain.com>"

# UploadThing (for file uploads)
UPLOADTHING_TOKEN="your-uploadthing-token"

# Admin Seed (optional - used by `npm run db:seed`)
# If not set, defaults to admin@cnec.cm / Admin@CNEC2026
ADMIN_EMAIL="admin@cnec.cm"
ADMIN_PASSWORD="Admin@CNEC2026"
ADMIN_NAME="CNEC Admin"
