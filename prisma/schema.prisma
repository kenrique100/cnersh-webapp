generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String      @id @default(uuid())
  email               String      @unique
  name                String?
  role                String?
  bio                 String?
  hasDeletePermission Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  emailVerified       Boolean     @default(false)
  image               String?
  gender              Gender?
  profession          String?
  title               String?
  sessions            Session[]
  accounts            Account[]
  banned              Boolean?
  banReason           String?
  banExpires          DateTime?

  // Extended profile fields
  expertiseTags        String[]    @default([])
  pendingActivation    Boolean     @default(false)
  activationExpiresAt  DateTime?

  posts              Post[]
  comments           Comment[]
  likes              Like[]
  projects           Project[]           @relation("ProjectOwner")
  assignedProjects   Project[]           @relation("ProjectReviewer")
  communityTopics    CommunityTopic[]
  communityReplies   CommunityReply[]
  reports            Report[]        @relation("ReportAuthor")
  notifications      Notification[]
  auditLogs          AuditLog[]
  commentLikes       CommentLike[]
  communityTopicLikes CommunityTopicLike[]
  reviewAssignments  ReviewAssignment[]
  coiDeclarations    COIDeclaration[]
  evaluationReports  EvaluationReport[]
  saeReports         SAEReport[]
  aarApplications    AARApplication[]
  appeals            Appeal[]
  files              File[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum Gender {
  male
  female

  @@map("gender")
}

// ─── File Storage (replaces Vercel Blob) ───────────────────
// Files are stored as base64 strings in a TEXT column.
// Keep individual files ≤ 10 MB to avoid bloating the DB.
// Use the /api/files/[fileId] route to serve them back.

enum FileType {
  avatar
  protocol
  document
  image
  video
  audio

  @@map("file_type")
}

model File {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  /// File size in bytes (original, before base64 encoding)
  size      Int
  /// Base64-encoded file content stored as TEXT
  data      String
  type      FileType
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([userId, type])
  @@index([createdAt])
  @@map("file")
}

// ─── Feed System ───────────────────────────────────────────

model Post {
  id              String      @id @default(uuid())
  content         String
  image           String?
  video           String?
  images          String[]    @default([])
  videos          String[]    @default([])
  tags            String[]    @default([])
  linkUrl         String?
  linkType        String?
  commentsEnabled Boolean     @default(true)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments        Comment[]
  likes           Like[]
  deleted         Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([deleted, createdAt])
  @@map("post")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  commentLikes CommentLike[]
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@map("comment")
}

model CommentLike {
  id           String   @id @default(uuid())
  commentId    String
  comment      Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDislike    Boolean  @default(false)
  reactionType String   @default("Like")
  createdAt    DateTime @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_like")
}

model Like {
  id           String   @id @default(uuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactionType String   @default("Like")
  createdAt    DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("like")
}

// ─── Project Submission System ─────────────────────────────

model Project {
  id              String              @id @default(uuid())
  trackingCode    String              @unique
  referenceNumber String?
  title           String
  description     String
  objectives      String?
  category        String
  location        String?
  timeline        String?
  budget          String?
  document        String?
  formData        Json?
  status          ProjectStatus       @default(DRAFT)
  feedback        String?
  userId          String
  user            User                @relation("ProjectOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignedToId    String?
  assignedTo      User?               @relation("ProjectReviewer", fields: [assignedToId], references: [id], onDelete: SetNull)
  statusHistory   ProjectStatusHistory[]
  reviewAssignments ReviewAssignment[]
  appeal          Appeal?
  aarApplication  AARApplication?
  saeReports      SAEReport[]
  deleted         Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([trackingCode])
  @@index([createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([category, status])
  @@map("project")
}

model ProjectStatusHistory {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    ProjectStatus
  comment   String?
  changedBy String
  createdAt DateTime      @default(now())

  @@index([projectId])
  @@map("project_status_history")
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  RETURNED_INCOMPLETE
  PENDING_REVIEW
  UNDER_REVIEW
  REVIEW_COMPLETE
  SESSION_SCHEDULED
  APPROVED
  APPROVED_WITH_CONDITIONS
  REJECTED
  UNDER_APPEAL
  APPEAL_RESOLVED
  ARCHIVED

  @@map("project_status")
}

// ─── Community Discussion System ───────────────────────────

model CommunityTopic {
  id          String           @id @default(uuid())
  title       String
  content     String
  category    String
  image       String?
  images      String[]         @default([])
  video       String?
  videos      String[]         @default([])
  documents   String[]         @default([])
  linkUrl     String?
  chatEnabled Boolean          @default(true)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies     CommunityReply[]
  likes       CommunityTopicLike[]
  deleted     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@map("community_topic")
}

model CommunityTopicLike {
  id        String         @id @default(uuid())
  topicId   String
  topic     CommunityTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDislike Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@unique([topicId, userId])
  @@index([topicId])
  @@index([userId])
  @@map("community_topic_like")
}

model CommunityReply {
  id          String          @id @default(uuid())
  content     String
  image       String?
  images      String[]        @default([])
  video       String?
  videos      String[]        @default([])
  audio       String?
  audios      String[]        @default([])
  voiceNote   String?
  document    String?
  documents   String[]        @default([])
  linkUrl     String?
  pollQuestion String?
  pollOptions  String[]       @default([])
  pollVotes    Json?
  eventTitle   String?
  eventDate    DateTime?
  eventLocation String?
  topicId     String
  topic       CommunityTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      CommunityReply? @relation("ReplyToReply", fields: [parentId], references: [id])
  children    CommunityReply[] @relation("ReplyToReply")
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deleted     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([topicId])
  @@index([userId])
  @@index([parentId])
  @@map("community_reply")
}

// ─── Reporting System ──────────────────────────────────────

model Report {
  id          String       @id @default(uuid())
  reason      String
  contentType ReportTarget
  contentId   String
  userId      String
  user        User         @relation("ReportAuthor", fields: [userId], references: [id], onDelete: Cascade)
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([contentType, contentId])
  @@map("report")
}

enum ReportTarget {
  POST
  COMMENT
  TOPIC
  REPLY

  @@map("report_target")
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED

  @@map("report_status")
}

// ─── Notification System ───────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notification")
}

enum NotificationType {
  PROJECT_STATUS
  REVIEW_ASSIGNED
  COMMENT
  LIKE
  MENTION
  SYSTEM
  ANNOUNCEMENT

  @@map("notification_type")
}

// ─── Audit Log System ──────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  targetId  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

// ─── Pages System (Admin-managed) ──────────────────────────

model Page {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Page?      @relation("PageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[]     @relation("PageChildren")
  items     PageItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([name])
  @@index([parentId])
  @@map("page")
}

model PageItem {
  id        String   @id @default(uuid())
  name      String
  url       String?
  fileUrl   String?
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([pageId])
  @@map("page_item")
}

// ─── Review Assignment System ───────────────────────────────

model ReviewAssignment {
  id               String                  @id @default(uuid())
  projectId        String
  project          Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId       String
  reviewer         User                    @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  status           ReviewAssignmentStatus  @default(PENDING_COI)
  dueDate          DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  coiDeclaration   COIDeclaration?
  evaluationReport EvaluationReport?

  @@unique([projectId, reviewerId])
  @@index([projectId])
  @@index([reviewerId])
  @@map("review_assignment")
}

enum ReviewAssignmentStatus {
  PENDING_COI
  ACTIVE
  EXCLUDED
  COMPLETED

  @@map("review_assignment_status")
}

// ─── COI Declaration System ─────────────────────────────────

model COIDeclaration {
  id           String           @id @default(uuid())
  assignmentId String           @unique
  assignment   ReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  hasCOI       Boolean
  details      String?
  declaredAt   DateTime         @default(now())

  @@index([userId])
  @@map("coi_declaration")
}

// ─── Evaluation Report System ───────────────────────────────

model EvaluationReport {
  id               String                    @id @default(uuid())
  assignmentId     String                    @unique
  assignment       ReviewAssignment          @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewerId       String
  reviewer         User                      @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  socialValue                          Int?
  scientificValidity                   Int?
  riskBenefitAnalysis                  Int?
  participantSelection                 Int?
  informedConsentProcess               Int?
  confidentialityDataProtection        Int?
  collaborativePartnership             Int?

  socialValueComment                   String?
  scientificValidityComment            String?
  riskBenefitAnalysisComment           String?
  participantSelectionComment          String?
  informedConsentProcessComment        String?
  confidentialityDataProtectionComment String?
  collaborativePartnershipComment      String?

  overallScore       Float?
  recommendation     EvaluationRecommendation?
  generalComments    String?
  additionalCriteria Json?

  status             EvaluationStatus  @default(DRAFT)
  submittedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([reviewerId])
  @@map("evaluation_report")
}

enum EvaluationRecommendation {
  FAVORABLE
  FAVORABLE_WITH_CONDITIONS
  UNFAVORABLE

  @@map("evaluation_recommendation")
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED

  @@map("evaluation_status")
}

// ─── Committee Session System ───────────────────────────────

model CommitteeSession {
  id          String        @id @default(uuid())
  sessionType SessionType   @default(ORDINARY)
  sessionDate DateTime
  venue       String?
  agenda      String[]      @default([])
  status      SessionStatus @default(SCHEDULED)
  quorumMet   Boolean?
  minutes     String?
  notes       String?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([sessionDate])
  @@index([status])
  @@map("committee_session")
}

enum SessionType {
  ORDINARY
  EXTRAORDINARY

  @@map("session_type")
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED

  @@map("session_status")
}

// ─── Appeal System ──────────────────────────────────────────

model Appeal {
  id           String       @id @default(uuid())
  projectId    String       @unique
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appellantId  String
  appellant    User         @relation(fields: [appellantId], references: [id], onDelete: Cascade)
  grounds      String
  evidence     String?
  status       AppealStatus @default(PENDING)
  decision     String?
  decisionDate DateTime?
  filedAt      DateTime     @default(now())
  deadlineAt   DateTime
  updatedAt    DateTime     @updatedAt

  @@index([appellantId])
  @@map("appeal")
}

enum AppealStatus {
  PENDING
  UPHELD
  REJECTED
  EXPIRED

  @@map("appeal_status")
}

// ─── AAR Application System ─────────────────────────────────

model AARApplication {
  id              String    @id @default(uuid())
  projectId       String    @unique
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicantId     String
  applicant       User      @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  status          AARStatus @default(DRAFT)
  submittedAt     DateTime?
  drosReceivedAt  DateTime?
  drosDueDate     DateTime?
  aarRefNumber    String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([applicantId])
  @@map("aar_application")
}

enum AARStatus {
  DRAFT
  SUBMITTED
  RECEIVED_BY_DROS
  CLARIFICATION_REQUESTED
  AUTHORIZED
  INADMISSIBLE

  @@map("aar_status")
}

// ─── SAE Report System ──────────────────────────────────────

model SAEReport {
  id               String       @id @default(uuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporterId       String
  reporter         User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  eventType        SAEEventType
  eventDate        DateTime
  description      String
  immediateActions String?
  isLate           Boolean      @default(false)
  reportedAt       DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([projectId])
  @@index([reporterId])
  @@map("sae_report")
}

enum SAEEventType {
  ADVERSE_EVENT
  SERIOUS_ADVERSE_EVENT
  UNEXPECTED_ADVERSE_EVENT
  LIFE_THREATENING
  FATAL

  @@map("sae_event_type")
}
